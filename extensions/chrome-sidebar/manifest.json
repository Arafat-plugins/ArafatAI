{
  "manifest_version": 3,
  "name": "FLUID Sidebar",
  "version": "0.1.0",
  "description": "Local FLUID sidebar that sends page snapshots to the Codex CLI bridge.",
  "icons": {
    "16": "assets/aql-brain-16.png",
    "32": "assets/aql-brain-32.png",
    "48": "assets/aql-brain-48.png",
    "128": "assets/aql-brain-128.png"
  },
  "permissions": ["activeTab", "scripting", "sidePanel", "tabs"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:8792/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "FLUID",
    "default_icon": {
      "16": "assets/aql-brain-16.png",
      "32": "assets/aql-brain-32.png",
      "48": "assets/aql-brain-48.png",
      "128": "assets/aql-brain-128.png"
    }
  }
}
